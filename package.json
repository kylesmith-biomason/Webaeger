{
  "name": "grill-master",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @grill-master/server",
    "dev:web": "npm run dev -w @grill-master/web",
    "build": "npm run build -w @grill-master/web && npm run build -w @grill-master/server",
    "start": "npm run start -w @grill-master/server",
    "deploy": "bash scripts/deploy.sh"
  },
  "engines": {
    "node": ">=20"
  }
}
