# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# On the Pi, production defaults also live in deploy/webaeger.service.
# Values in the systemd unit override these if both are set.

# mock | rtd
SENSOR=mock

PORT=3000

# Sensor poll interval in milliseconds (30000 = 30s)
POLL_MS=5000

# F | C
TEMP_UNIT=F

# SQLite path (relative to cwd, or absolute)
DB_PATH=data/grillmaster.db

# Used only when SENSOR=rtd
I2C_BUS=1
# Comma-separated I2C addresses, one per probe (order matches PROBE_LABELS)
RTD_ADDRS=0x70,0x66
# Legacy single-address fallback still works: RTD_ADDR=0x70

# Probe channel labels (toggle above live temp)
PROBE_LABELS=Pit,Meat

# URL encoded in the phone QR (tap "Grill Master" banner).
# On the Pi, set to your LAN address if auto-detect is wrong, e.g.:
# PUBLIC_URL=http://192.168.1.133:3000
# PUBLIC_URL=
