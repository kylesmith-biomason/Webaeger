# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# On the Pi, production defaults also live in deploy/webaeger.service.
# Values in the systemd unit override these if both are set.

# mock | rtd
SENSOR=mock

PORT=3000

# Sensor poll interval in milliseconds (30000 = 30s)
POLL_MS=10000

# F | C
TEMP_UNIT=F

# SQLite path (relative to cwd, or absolute)
DB_PATH=data/grillmaster.db

# Used only when SENSOR=rtd
I2C_BUS=1
RTD_ADDR=0x66
